# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_64_CHAR_RANDOM_HEX

# ─────────────────────────────────────────────
# Database (SQLite)
# ─────────────────────────────────────────────
# Use an absolute path in production so the file is always in the same place
DB_PATH=/var/www/incubator/incubator.db

# ─────────────────────────────────────────────
# MQTT Broker
# ─────────────────────────────────────────────
MQTT_BROKER=45.79.206.183
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=incubator_backend_prod

# ─────────────────────────────────────────────
# Device
# ─────────────────────────────────────────────
DEVICE_ID=device1
DEVICE_TOPIC_PREFIX=incubator/device1

# ─────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# In production this is your server IP or domain.
# If frontend is served by the same Express process, you can leave this as the server URL.
# ─────────────────────────────────────────────
FRONTEND_URL=http://YOUR_SERVER_IP
